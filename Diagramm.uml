@startuml CNF_Analyzer

skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam linetype ortho

' ─── Interfaces ───────────────────────────────────────────────────────────────

package "interfaces" #EEBBFF {

    interface IMemoryAnalyzer {
        +analyze(filePath : QString) : bool
        +hasError() : bool
        +hasMemoryLeak() : bool
        +printElements() : void
    }

    interface ISATSolver {
        +solve(connections : QList<Connection>,\n       elements : QMap<QString, TreeElement*>) : bool
    }

    interface IMemoryOperation {
        +handles(value : QJsonValue) : bool
        +execute(tree : Tree*,\n         varName : QString,\n         clauseId : int,\n         value : QJsonValue,\n         builder : GraphBuilder&,\n         hasMemoryLeak : bool&) : void
    }
}

' ─── Analysis ─────────────────────────────────────────────────────────────────

package "analysis" #CCEECC {

    class MemoryAnalyzer {
        -solver_ : unique_ptr<ISATSolver>
        -treeManager_ : unique_ptr<TreeManager>
        -graphBuilder_ : unique_ptr<GraphBuilder>
        -rowProcessor_ : unique_ptr<RowProcessor>
        -operations_ : QList<IMemoryOperation*>
        -has_error_ : bool
        -has_memory_leak_ : bool
        --
        +MemoryAnalyzer(solver : unique_ptr<ISATSolver>)
        +analyze(filePath : QString) : bool
        +hasError() : bool
        +hasMemoryLeak() : bool
        +printElements() : void
        -registerDefaultOperations() : void
        -analyzeAllTrees(rowId : int) : void
    }

    class GraphBuilder {
        -manager_ : TreeManager*
        -current_position_ : int
        -memory_var_index_ : int
        -max_bytes_count_ : size_t
        --
        +GraphBuilder(manager : TreeManager*)
        +findOrCreateElement(tree : Tree*, name : QString, type : int) : TreeElement*
        +findOrCreateConnection(tree : Tree*, from : QString, to : QString, position : int) : Connection*
        +removeRootLinkClauses(tree : Tree*, rootName : QString, varName : QString) : void
        +mergeTrees(target : Tree*, source : Tree*) : void
        +findLeaves(tree : Tree*) : QList<QString>
        +findMemoryElement(tree : Tree*) : TreeElement*
        +{static} findSetBitPosition(bv : BoolVector) : size_t
        +nextPosition() : int
        +nextMemoryVarIndex() : int
        +maxBytesCount() : size_t
    }

    class RowProcessor {
        -manager_ : TreeManager*
        -builder_ : GraphBuilder*
        -operations_ : QList<IMemoryOperation*>
        -functions_ : QJsonObject
        -stacks_ : QJsonObject
        -has_error_ : bool
        -has_memory_leak_ : bool
        --
        +RowProcessor(manager : TreeManager*, builder : GraphBuilder*,\n              operations : QList<IMemoryOperation*>)
        +setFunctions(functions : QJsonObject, stacks : QJsonObject) : void
        +processRow(row : QJsonObject, currentTree : Tree*&, clauseId : int) : void
        +hasError() : bool
        +hasMemoryLeak() : bool
        -getOrCreateTree(name : QString) : Tree*
        -processBody(bodyValue : QJsonValue, currentTree : Tree*, clauseId : int) : void
        -processBranch(branchObj : QJsonObject, currentTree : Tree*, clauseId : int) : void
        -processOperation(opObject : QJsonObject, currentTree : Tree*, clauseId : int) : void
        -processLoop(loopObject : QJsonObject, currentTree : Tree*, clauseId : int) : void
        -dispatchMemoryOp(tree : Tree*, varName : QString,\n                   clauseId : int, value : QJsonValue) : void
    }
}

' ─── Solver ───────────────────────────────────────────────────────────────────

package "solver" #FFCCDD {

    class MinisatSolver {
        +solve(connections : QList<Connection>,\n       elements : QMap<QString, TreeElement*>) : bool
    }
}

' ─── Operations ───────────────────────────────────────────────────────────────

package "operations" #FFFACC {

    class MallocOperation {
        +handles(value : QJsonValue) : bool
        +execute(tree : Tree*, varName : QString, clauseId : int,\n         value : QJsonValue, builder : GraphBuilder&,\n         hasMemoryLeak : bool&) : void
    }

    class FreeOperation {
        +handles(value : QJsonValue) : bool
        +execute(tree : Tree*, varName : QString, clauseId : int,\n         value : QJsonValue, builder : GraphBuilder&,\n         hasMemoryLeak : bool&) : void
    }

    class NullOperation {
        +handles(value : QJsonValue) : bool
        +execute(tree : Tree*, varName : QString, clauseId : int,\n         value : QJsonValue, builder : GraphBuilder&,\n         hasMemoryLeak : bool&) : void
    }

    class SpecialPtrOperation {
        +handles(value : QJsonValue) : bool
        +execute(tree : Tree*, varName : QString, clauseId : int,\n         value : QJsonValue, builder : GraphBuilder&,\n         hasMemoryLeak : bool&) : void
    }
}

' ─── Model ────────────────────────────────────────────────────────────────────

package "model" #DDEEFF {

    class TreeManager {
        -trees_ : QMap<QString, Tree*>
        -treeCount_ : int
        --
        +addTree(name : QString, tree : Tree*) : void
        +removeTree(name : QString) : void
        +getTree(name : QString) : Tree*
        +containsTree(name : QString) : bool
        +getTreeCount() : int
        +getAllTrees() : QMap<QString, Tree*>
        +clear() : void
    }

    class Tree {
        -name_ : QString
        -elements_ : QMap<QString, TreeElement*>
        -connections_ : QList<Connection>
        -root_ : TreeElement*
        --
        +Tree(name : QString)
        +getName() : QString
        +getRoot() : TreeElement*
        +getElements() : QMap<QString, TreeElement*>
        +getConnections() : QList<Connection>
        +addElement(name : QString, element : TreeElement*) : bool
        +removeElement(name : QString) : bool
        +findElement(name : QString) : TreeElement*
        +addConnection(connection : Connection) : void
        +removeConnection(from : QString, to : QString) : bool
        +findConnection(from : QString, to : QString) : Connection*
        +isEmpty() : bool
        +clear() : void
        +isValid() : bool
    }

    class TreeElement {
        -name_ : QString
        -type_ : int
        -position_ : int
        --
        +TreeElement(name : QString, type : int, position : int)
        +getName() : QString
        +getType() : int
        +getPosition() : int
        +getTypeName() : QString
        +setName(name : QString) : void
        +setType(type : int) : void
        +setPosition(position : int) : void
        +isRoot() : bool
        +isMemory() : bool
        +isNull() : bool
        +isLeftVariable() : bool
        +isRightVariable() : bool
        +isValid() : bool
    }

    enum TreeElementType {
        ROOT
        MEMORY
        NULL_ELEMENT
        LEFT_VARIABLE
        RIGHT_VARIABLE
        MAGIC_POINTER
    }

    class Connection {
        -from_ : QString
        -to_ : QString
        -positiveVector_ : BoolVector
        -negativeVector_ : BoolVector
        -position_ : int
        --
        +Connection(from : QString, to : QString,\n            positiveVector : BoolVector,\n            negativeVector : BoolVector, position : int)
        +getFrom() : QString
        +getTo() : QString
        +getPositiveVector() : BoolVector
        +getNegativeVector() : BoolVector
        +getPosition() : int
        +setPositiveBit(bitIndex : size_t) : void
        +clearPositiveBit(bitIndex : size_t) : void
        +getPositiveBit(bitIndex : size_t) : bool
        +setNegativeBit(bitIndex : size_t) : void
        +clearNegativeBit(bitIndex : size_t) : void
        +getNegativeBit(bitIndex : size_t) : bool
        +isValid() : bool
    }

    class BoolVector {
        -vector : unsigned char*
        -bits : size_t
        -bytes : size_t
        --
        +BoolVector()
        +BoolVector(bits : size_t)
        +{static} calculateBytes(bits : size_t) : size_t
        +setBit(position : size_t) : void
        +clearBit(position : size_t) : void
        +getBit(position : size_t) : bool
        +isZero() : bool
        +size() : size_t
        +count_bytes() : size_t
        +resize(newSize : size_t) : void
        +getVector() : const unsigned char*
        +print() : void
    }
}

' ─── Relationships ────────────────────────────────────────────────────────────

' implements
MemoryAnalyzer   ..|> IMemoryAnalyzer
MinisatSolver    ..|> ISATSolver
MallocOperation  ..|> IMemoryOperation
FreeOperation    ..|> IMemoryOperation
NullOperation    ..|> IMemoryOperation
SpecialPtrOperation ..|> IMemoryOperation

' composition (MemoryAnalyzer owns its collaborators)
MemoryAnalyzer "1" *-- "1" TreeManager
MemoryAnalyzer "1" *-- "1" GraphBuilder
MemoryAnalyzer "1" *-- "1" RowProcessor
MemoryAnalyzer "1" *-- "1" ISATSolver

' aggregation (MemoryAnalyzer holds references to operation objects)
MemoryAnalyzer "1" o-- "4" IMemoryOperation

' uses
GraphBuilder    --> TreeManager   : uses
RowProcessor    --> TreeManager   : uses
RowProcessor    --> GraphBuilder  : uses
RowProcessor    "1" o-- "4" IMemoryOperation : dispatches

' model composition
TreeManager "1" *-- "0..*" Tree
Tree        "1" *-- "0..*" TreeElement
Tree        "1" *-- "0..*" Connection
Connection  "1" *-- "2"    BoolVector

' enum
TreeElement ..> TreeElementType : uses

@enduml
